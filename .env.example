# Gemini API Key (Required)
GEMINI_API_KEY=
# Gemini Model selection (e.g. gemini-3.1-flash-lite, gemini-3.5-flash, or gemma-4-31b-it)
GEMINI_MODEL=gemini-3.1-flash-lite

# System Password for secure actions
SYSTEM_PASSWORD=

# Gmail integration
GMAIL_CREDENTIALS_PATH=./config/credentials.json

# Optional: OpenAI API Key
OPENAI_API_KEY=

# Local Ollama model selection (e.g. gemma4:e4b)
OLLAMA_MODEL=gemma4:e4b

# Browser Control Settings
BROWSER_TYPE=chromium
BROWSER_HEADLESS=False
BROWSER_SLOW_MO=1000

# GitHub Integration
GITHUB_TOKEN=
GITHUB_USERNAME=

# LangSmith Tracing & Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT="hermes-assistant-backend"